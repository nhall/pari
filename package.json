{
  "name": "pari-components",
  "version": "0.0.1",
  "description": "Accessible web component library",
  "type": "module",
  "main": "./dist/components.iife.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/components.iife.js"
    },
    "./disclosure": {
      "types": "./dist/components/disclosure/disclosure.d.ts",
      "import": "./dist/components/disclosure.js"
    },
    "./accordion": {
      "types": "./dist/components/accordion/accordion.d.ts",
      "import": "./dist/components/accordion.js"
    },
    "./tabs": {
      "types": "./dist/components/tabs/tabs.d.ts",
      "import": "./dist/components/tabs.js"
    },
    "./dialog": {
      "types": "./dist/components/dialog/dialog.d.ts",
      "import": "./dist/components/dialog.js"
    },
    "./popover": {
      "types": "./dist/components/popover/popover.d.ts",
      "import": "./dist/components/popover.js"
    },
    "./nav-disclosure": {
      "types": "./dist/components/nav-disclosure/nav-disclosure.d.ts",
      "import": "./dist/components/nav-disclosure.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && vite build --config vite.config.iife.ts",
    "preview": "vite preview",
    "test": "vitest --project=storybook --run",
    "test:watch": "vitest --project=storybook",
    "storybook": "storybook dev -p 6006 --host 0.0.0.0",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/web-components-vite": "^10.3.3",
    "@vitest/browser-playwright": "^4.1.1",
    "lit": "^3.3.2",
    "storybook": "^10.3.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.1"
  }
}
